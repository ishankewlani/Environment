# Earth Immune System AI — Environment Variables Example
# Copy this file to .env and fill in real values for production use.
# Never commit .env to version control.

# App settings
DEMO_MODE=true

# Set to true and provide credentials to enable real SMS alerts (Phase 2+)
REAL_SMS_ENABLED=false

# SMS Gateway credentials (Phase 2 — leave blank for Phase 1)
SMS_API_KEY=
SMS_SENDER_ID=

# Satellite API key (Phase 2 — leave blank for Phase 1)
SATELLITE_API_KEY=
