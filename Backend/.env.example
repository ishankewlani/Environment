# Rakshak – Earth Immune System AI
# Copy to Backend/.env and replace placeholders. Never commit Backend/.env.

# Application
DEMO_MODE=false
REAL_SMS_ENABLED=false
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-vercel-domain.vercel.app
CORS_ORIGIN_REGEX=https://[a-zA-Z0-9-]+\.vercel\.app

# Live weather
OPENWEATHER_API_KEY=your-openweather-api-key

# NASA FIRMS near-real-time fire hotspots
NASA_FIRMS_MAP_KEY=your-nasa-firms-map-key

# Copernicus Sentinel-2 Statistical API
COPERNICUS_CLIENT_ID=your-copernicus-client-id
COPERNICUS_CLIENT_SECRET=your-copernicus-client-secret

# Official Indian open datasets; used with a selected resource ID
DATA_GOV_IN_API_KEY=your-data-gov-in-api-key

# Supabase permanent backend storage
SUPABASE_URL=https://your-project-reference.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-backend-secret-key

# Private access for feedback response/export endpoints
FEEDBACK_ADMIN_KEY=generate-with-python-secrets-token-urlsafe

# No keys are required for NASA POWER, SoilGrids, IMD CAP RSS or SACHET CAP.
